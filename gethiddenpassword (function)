#include <conio.h>   // Required for _getch()

string getHiddenPassword()
{
    string password = "";
    char ch;

    while ((ch = _getch()) != 13) // Enter key
    {
        if (ch == 8) // Backspace
        {
            if (!password.empty())
            {
                password.pop_back();
                cout << "\b \b";
            }
        }
        else
        {
            password += ch;
            cout << "*";   // show * instead of actual character
        }
    }

    cout << endl;
    return password;
}
